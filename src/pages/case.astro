---
import Layout from "@layouts/Layout.astro";
import CaseStudyArticle from "@components/CaseStudyArticle.astro";
import ScrollTest from "@components/FinancialTools.astro";
---

<Layout>
  <!-- Banner -->
<ScrollTest />

  <article class="full-width banner">
      <p class="lato-regular-16">CASE STUDIES</p>
    <h1>Taxes & Efficiency</h1>
    <p class="lato-regular-16">
      Our achievements reflect the close collaboration between our expert teams
      and our esteemed clientele. We cultivate a workplace that champions peak
      performance and guarantees client satisfaction.
    </p>
  </article>

  <CaseStudyArticle />
</Layout>

<style>
  @layer components {
    .banner {
      text-align: center;
      margin: var(--space-s);
      p {
        max-width: 700px;
        margin: auto;
      }
      padding: var(--space-l);
      padding-bottom: 3rlh;
      background-color: var(--color-surface-secondary);
    }
  }
</style>
