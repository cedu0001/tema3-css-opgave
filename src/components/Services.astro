---
import ServiceCard from "@components/ServiceCard.astro";
import servicesData from "@data/services.json";
import DynamicImage from "@helpers/DynamicImage.astro";
---

<div class="services">
  {servicesData.services.map((service) => <ServiceCard service={service} />)}
</div>

<style>
  @layer components {
    .services {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
      margin-top: -2rlh;
      > * {
        max-width: 320px;
      }
    }
  }
</style>
