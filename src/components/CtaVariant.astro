---
const { href } = Astro.props;
const { theme = "default" } = Astro.props;
---

<a href={href} data-surface={theme}><slot /></a>

<style>
	a[data-surface="default"] {
		border-radius: var(--border-42);
		padding: var(--space-s) var(--space-l);
		background-color: var(--color-action);
		cursor: pointer;
		border: 3px solid var(--color-action);
	}

	a[data-surface="white"] {
		background-color: var(--color-surface-secondary);
		border-radius: var(--border-42);
		padding: var(--space-s) var(--space-l);
		cursor: pointer;
		border: 3px solid var(--color-surface-secondary);
	}

	a[data-surface="black"] {
		background-color: var(--color-ui-primary);
		color: var(--color-on-ui-primary);
		border-radius: var(--border-42);
		padding: var(--space-s) var(--space-l);
		cursor: pointer;
		border: 3px solid var(--color-ui-primary);
	}
</style>
