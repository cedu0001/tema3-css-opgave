---
import "../styles/main.css";

import experience from "@data/experience.json";
---

<section class="full-width">
	<div class="container">
		<div class="grid">
			<div>
				<p>{experience.eyebrow}</p>
				<h3>{experience.title}</h3>
				<p>{experience.subtitle}</p>
			</div>
			<div class="stats">
				{
					experience.stats.map((stat) => (
						<div class="flex">
							<div
								class="stat"
								style={`--percent: ${stat.value}`}
							/>
							<h4>{stat.label}</h4>
						</div>
					))
				}
			</div>
		</div>
	</div>
</section>

<style>
	@layer components {
		section {
			background-color: var(--color-surface-highlight);
			padding-block: 4rlh;
		}
		.stats {
			display: flex;
			flex-direction: row;
			justify-content: center;
			gap: 1rem;
		}

		.grid {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
		}

		div.container {
			container-type: inline-size;
			container-name: core-values;
		}

		@container core-values (width < 900px) {
			div.grid {
				grid-template-columns: 1fr;

				div:nth-child(1) p:nth-child(3) {
					margin-bottom: var(--space-m);
				}
			}
		}

		@container core-values (width < 550px) {
			div.grid {
				grid-template-columns: 1fr;

				div:nth-child(1) p:nth-child(3) {
					margin-bottom: var(--space-m);
				}
			}

			div.stats {
				display: flex;
				flex-wrap: wrap;

				div.flex {
					h4 {
						margin-bottom: 30px;
					}
				}
			}
		}

		/* @container cards (width < 550px) {
			div.grid_1-1-1-1 {
				grid-template-columns: 1fr;
			}

			div.grid_3-1 {
				display: flex;
				flex-wrap: wrap;
				gap: 1rem;

				:nth-child(2) {
					margin-top: var(--space-m);
				}
			}
		} */

		.flex {
			display: grid;
			justify-items: center;
			gap: 1rem;
			width: min(200px, 100% - 1rem);

			h4 {
				place-self: center;
				font-size: var(--step-1);
			}
		}

		div.grid div {
			p {
				color: var(--color-text);
			}
		}

		@property --animatedNumber {
			syntax: "<number>";
			initial-value: 0;
			inherits: true;
		}

		.stat {
			--percentage: calc(var(--animatedNumber) * 1%);
			--border-width: 5px;
			aspect-ratio: 1;
			width: min(150px, 100% - 0.2rem);
			border-radius: calc(infinity * 1px);
			border: var(--border-width) solid #0000;
			content: "";
			background:
				radial-gradient(
						circle at 50% calc(var(--border-width) / 2),
						white calc(var(--border-width) / 2),
						#0000 0
					)
					border-box,
				linear-gradient(var(--color-surface-highlight)) padding-box,
				conic-gradient(white var(--percentage), #daae3c 0) border-box;
			display: grid;
			container: stat / inline-size;
			animation: percentage-animation 2s forwards;
			animation-timeline: view();
			animation-range: entry 1% cover 55%;

			&::before,
			&::after {
				grid-area: 1 / 1;
			}

			&::after {
				counter-reset: stat round(var(--animatedNumber));
				grid-area: 1 / 1;
				content: counter(stat) "%";
				place-self: center;
				font-size: var(--step-1);
			}

			&::before {
				content: "";
				aspect-ratio: 1;
				border-radius: calc(infinity * 1px);
				border: solid 3px white;
				offset-path: border-box;
				offset-distance: var(--percentage);
				offset-anchor: 50% calc(50% - var(--border-width) / 2);
				width: calc(var(--border-width) * 4);
				background: var(--color-ui-primary);
			}
		}

		@keyframes percentage-animation {
			from {
				--animatedNumber: 0;
			}
			to {
				--animatedNumber: var(--percent);
			}
		}

		@media (prefers-reduced-motion: reduce) {
			.stat {
				animation: none;
				--animatedNumber: var(--percent);
			}
		}
	}
</style>
