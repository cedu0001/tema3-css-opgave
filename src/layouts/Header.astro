---
import "../styles/main.css";
import CtaVariant from "@components/CtaVariant.astro";
---

<header>
	<div class="grid">
		<a href="/"><h4>Ask<span class="yellow-text">Experts</span></h4></a>

		<div class="nav">
			<ul popover id="menu">
				<li><a href="/">Home</a></li>
				<li><a href="/case">Case Study</a></li>
				<li><a href="">Team</a></li>
				<li><a href="">About</a></li>
			</ul>
			<button popovertarget="menu" id="menu-button">Menu</button>
		</div>

		<div class="login-btn">
			<button popovertarget="pop"
				><CtaVariant theme="login">Login</CtaVariant></button
			>
		</div>

		<aside id="pop" popover="manual">
			<div>
				<h3>Dashboard Login</h3>
				<form>
					<div>
						<p>Email adress</p>
						<input type="email" placeholder="" />
					</div>

					<div>
						<p>Password</p>
						<input type="password" placeholder="" />
					</div>

					<button type="submit" class="submit-btn"
						>Go to dashboard</button
					>
				</form>
			</div>
		</aside>
	</div>
</header>

<style>
	@layer components {
		header {
			background-color: #030712;
			padding: var(--space-l) 0px;
		}

		.grid {
			display: grid;
			grid-template-columns: 1fr auto 1fr;
		}

		h4 {
			color: var(--color-on-ui-primary);
			grid-column: 1;
		}

		.login-btn button {
			border: none;
		}

		.nav {
			grid-column: 2;
			align-self: center;

			ul {
				display: none;
				flex-direction: row;
				justify-content: space-between;
				background: transparent;
				border: none;
				list-style: none;

				&:popover-open {
					position-area: bottom span-left;
					display: grid;
					padding: 1rlh;
					background: var(--color-surface-primary);
					border: revert;
				}
				@media (width >= 600px) {
					margin: unset;
					position: unset;
					display: flex;
				}
			}

			button {
				@media (width >= 600px) {
					display: none;
				}
			}

			a {
				color: var(--color-on-ui-primary);
				font-size: var(--step-0);
				font-family: lato-regular;
				margin-right: var(--space-s);
			}
		}

		.login-btn {
			grid-column: 3;
			justify-self: end;
			align-self: center;
		}

		form {
			display: grid;
			gap: 1rlh;

			input {
				border-radius: var(--border-20);
				border: 1.5px solid #b1b1b1;
				padding: 5px var(--space-l);
			}
		}

		.nav button {
			anchor-name: --menu-btn;
		}

		.login-btn button {
			anchor-name: --login-btn;
		}

		#menu {
			position-anchor: --menu-btn;
		}

		#pop {
			position-anchor: --login-btn;
		}

		[popover] {
			background-color: var(--color-surface-secondary);
			position-anchor: --menu-button;
			position-area: bottom span-left;
			justify-self: anchor-center;
			position: absolute;
			position-try: flip-inline;
			border: none;
			padding: 10px;
			border-radius: var(--border-20);
		}

		/* mobil */
		@media (width <= 600px) {
			.grid {
				grid-template-columns: 1fr 1fr auto;
				gap: var(--space-s);
			}

			.nav {
				grid-column: 3/4;
				justify-self: end;
				align-self: center;
			}

			.login-btn {
				grid-row: 1;
				grid-column: 2/3;
			}

			button {
				background-color: var(--color-on-ui-primary);
				border-radius: var(--border-42);
				padding: 5px 5px;
				border: 3px solid var(--color-on-ui-primary);
				font-family: lato-regular;
			}

			li a {
				color: var(--color-text);
			}
		}
	}
</style>
